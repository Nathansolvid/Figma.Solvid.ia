# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Internal API shared secret (used by client to call /api/seed-admin, /api/notify-signup)
# Must match INTERNAL_SECRET on the server (Vercel env vars)
VITE_INTERNAL_SECRET=change-me-to-a-random-secret

# Server-side only — admin seed credentials (set in Vercel env vars, never VITE_*)
# INTERNAL_SECRET=change-me-to-a-random-secret
# SEED_ADMIN_EMAIL=admin@yourcompany.com
# SEED_ADMIN_PASSWORD=ChangeMe2026!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry Error Monitoring (optional - get DSN from https://sentry.io)
# VITE_SENTRY_DSN=https://xxxx@o1234.ingest.sentry.io/5678

# Demo mode — set to 'true' to bypass auth (dev only)
# VITE_DEMO_MODE=true
